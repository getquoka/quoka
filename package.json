{
  "name": "quoka",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prebuild": "npx electric-sql generate",
    "db:migrate:create": "npx prisma migrate dev --create-only --schema ./database/schema.prisma",
    "db:migrate:deploy": "npx prisma migrate deploy --schema ./database/schema.prisma",
    "db:migrate:mark-as-rolled-back": "npx prisma migrate resolve --schema ./database/schema.prisma --rolled-back ",
    "db:generate": "dotenv -e .env -- npx electric-sql generate --proxy postgresql://postgres:$PG_PROXY_PASSWORD@localhost:65432/postgres"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electric-sql": "^0.12.1",
    "next": "14.2.4",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/prettier": "^3.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.4",
    "postcss": "^8",
    "prettier": "^3.3.2",
    "prettier-plugin-organize-imports": "^3.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
